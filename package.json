{
  "name": "mycamp",
  "version": "1.0.0",
  "private": true,
  "description": "Automated TCS Camping (Switzerland) availability search for static accommodations, with encrypted history committed to the repo and a self-decrypting static dashboard.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "scrape": "tsx src/scrape.ts",
    "rotate-key": "tsx src/rotateKey.ts",
    "init-key": "tsx src/initKey.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  }
}
